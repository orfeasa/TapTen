limit_req_zone $binary_remote_addr zone=tapten_api_limit:10m rate=30r/m;

server {
    listen 80;
    listen [::]:80;
    server_name api.playtapten.com review.playtapten.com;

    # Update this path if TAPTEN_APP_ROOT is not /opt/tapten-backend/current.
    location /static/ {
        alias /opt/tapten-backend/current/backend/staticfiles/;
        access_log off;
        expires 1d;
    }

    location /tapten/ {
        limit_req zone=tapten_api_limit burst=60 nodelay;
        limit_req_status 429;
        proxy_pass http://127.0.0.1:8100;
        proxy_http_version 1.1;
        proxy_read_timeout 60s;
        proxy_connect_timeout 5s;
        proxy_send_timeout 60s;
        include proxy_params;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location / {
        proxy_pass http://127.0.0.1:8100;
        proxy_http_version 1.1;
        proxy_read_timeout 60s;
        proxy_connect_timeout 5s;
        proxy_send_timeout 60s;
        include proxy_params;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}
